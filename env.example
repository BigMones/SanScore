# ─── Supabase / PostgreSQL ─────────────────────────────────────────────────────
# Copia queste variabili dall'integrazione Supabase nel pannello Vercel:
# Vercel Project → Settings → Environment Variables
# oppure direttamente da Supabase → Project Settings → Database → Connection string

# Usata dal server come connessione principale (direct, non-pooled — consigliata per DDL)
SSCORE_POSTGRES_URL_NON_POOLING="postgres://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# Alternativa pooled (PgBouncer, porta 6543)
SSCORE_POSTGRES_URL="postgres://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?sslmode=require&supa=base-pooler.x"

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Stringa casuale e segreta per firmare i JWT. Mettila anche nelle env vars di Vercel.
JWT_SECRET="cambia-questa-stringa-con-qualcosa-di-segreto"
